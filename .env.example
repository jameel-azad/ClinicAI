# =============================================================================
# ClinicAI — environment template. Copy to `.env` and fill in real values.
# On the server, `.env` is read by docker-compose for BOTH variable
# substitution (${VAR} in docker-compose.prod.yml) and as the API container's
# env_file. NEVER commit the real .env.
# =============================================================================

# --- Public hostnames (used by Caddy for TLS + by compose for build args) ----
# No custom domain yet -> use sslip.io: <subdomain>.<SERVER_IP>.sslip.io
# Replace 203.0.113.5 with your VPS public IPv4 (keep the dots).
API_HOST=api.203.0.113.5.sslip.io
APP_HOST=app.203.0.113.5.sslip.io

# Full public URLs derived from the hosts above (https).
# NEXT_PUBLIC_API_URL is baked into the dashboard at BUILD time (build arg).
NEXT_PUBLIC_API_URL=https://api.203.0.113.5.sslip.io
PUBLIC_BASE_URL=https://api.203.0.113.5.sslip.io
DASHBOARD_URL=https://app.203.0.113.5.sslip.io

# --- Database & cache (service hostnames come from docker-compose) -----------
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
DATABASE_URL=postgresql+asyncpg://clinicai:CHANGE_ME_strong_db_password@postgres:5432/clinicai
REDIS_URL=redis://redis:6379

# --- App secrets (generate fresh; do NOT reuse dev values) -------------------
SECRET_KEY=CHANGE_ME_min_32_random_chars
# Fernet key (base64, 32 bytes). Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_fernet_base64_key

# --- LLM / STT providers (ROTATE the keys that leaked) -----------------------
GROQ_API_KEY=
GEMINI_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.5-flash
WHISPER_MODEL=whisper-large-v3

# --- Twilio WhatsApp (ROTATE the auth token that leaked) ---------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
SOAP_APPROVAL_CONTENT_SID=
APPOINTMENT_APPROVAL_CONTENT_SID=
DOCTOR_WHATSAPP_NUMBERS=Dr Jameel:+919801581020

# --- Clinic config -----------------------------------------------------------
CLINIC_NAME=ClinicAI
CLINIC_OPEN_HOUR=9
CLINIC_CLOSE_HOUR=20
REMINDER_MINUTES_BEFORE=120
DEMO_REMINDER_DELAY_MINUTES=1
FOLLOWUP_DEFAULT_DAYS=2
DEMO_FOLLOWUP_DELAY_MINUTES=1
CONSULTATION_TIMEOUT_MINUTES=2
JAMEEL_SCRIBE_URL=

# --- Google Calendar (mount the JSON files into the api container) -----------
GOOGLE_CALENDAR_ENABLED=True
GOOGLE_CALENDAR_CREDENTIALS_FILE=google_credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=google_token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
APPOINTMENT_DURATION_MINUTES=30
APPOINTMENT_SLOT_CANDIDATES=
